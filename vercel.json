{
    "buildCommand": "cd frontend && NODE_ENV=production npm run build",
    "outputDirectory": "frontend/dist",
    "installCommand": "npm install && npm install --prefix backend && npm install --prefix frontend",
    "env": {
        "NODE_ENV": "production"
    },
    "functions": {
        "api/index.js": {
            "memory": 1024,
            "maxDuration": 60
        }
    },
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "api/index.js"
        },
        {
            "src": "/.*\\.(js|css|png|jpg|jpeg|gif|svg|woff|woff2|eot|ttf|otf|json|webp|avif)$",
            "dest": "/$0"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}
