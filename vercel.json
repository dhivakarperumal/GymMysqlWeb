{
    "buildCommand": "npm run build:frontend",
    "outputDirectory": "frontend/dist",
    "env": {
        "NODE_ENV": "production"
    },
    "functions": {
        "api/index.js": {
            "memory": 1024,
            "maxDuration": 60
        }
    },
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api"
        },
        {
            "source": "/:path((?!api).*)",
            "destination": "/index.html"
        }
    ]
}